# Design layer — UX / visual work. Profiles: work, laptop, desktop.
cask "figma"
cask "cleanshot"          # screenshots, recordings, annotations, scrolling capture
cask "pika"               # onscreen color picker + WCAG contrast ratios
cask "imageoptim"         # lossless image compression
# Note: the "Contrast" app (usecontrast.com) is Mac App Store only, no cask.
# Pika covers color-picking + contrast; grab Contrast from the App Store if you
# prefer its UI.
