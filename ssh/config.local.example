# ~/.ssh/config.local — template.
# Copy to ~/.ssh/config.local and put your REAL hosts here. This path is
# gitignored and lives outside the tracked config, so server IPs, ports, and
# usernames never get committed. Loaded via `Include` from ~/.ssh/config.
#
# chmod 600 ~/.ssh/config.local

Host example
    HostName 203.0.113.10
    User you
    Port 22
    IdentityFile ~/.ssh/your_key
    IdentitiesOnly yes
